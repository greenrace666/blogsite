---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About';
const description = 'About your blog.';
const permalink = `${Astro.site.href}about`;
---

<BaseLayout title={title} description={description} permalink={permalink} current="about">
  <div class="container">
    <h1>About</h1>
    <p>Just blogging out my thoughts ✨</p>
    <p>Check out the main website <a href="https://nikilkrishna.netlify.app/">here</a></p>
  </div>
</BaseLayout>

